# ============================================================
# Ashapura Tiles & Marbles — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to version control.
# ============================================================

# ── Supabase (Frontend) ──────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Functions base URL — usually same as VITE_SUPABASE_URL + /functions/v1
# Leave blank to auto-derive from VITE_SUPABASE_URL
VITE_SUPABASE_FUNCTIONS_URL=https://your-project-id.supabase.co/functions/v1

# ── Supabase Secrets (Server-side only, set via CLI) ──────────
# These are NOT put in .env — they are set on the Supabase server:
#
#   npx supabase secrets set RESEND_API_KEY=re_xxxx OWNER_EMAIL=you@gmail.com --project-ref YOUR_PROJECT_REF
#
# RESEND_API_KEY  — Get from: https://resend.com (free: 3,000 emails/month)
# OWNER_EMAIL     — The email address that receives booking notifications

# ============================================================
# SQL: Create the 'bookings' table in Supabase SQL Editor
# ============================================================
#
# CREATE TABLE IF NOT EXISTS bookings (
#   id             UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#   name           TEXT NOT NULL,
#   email          TEXT NOT NULL,
#   phone          TEXT NOT NULL,
#   product        TEXT,
#   quantity       TEXT,
#   preferred_date DATE,
#   city           TEXT,
#   message        TEXT,
#   created_at     TIMESTAMP WITH TIME ZONE DEFAULT NOW()
# );
#
# ALTER TABLE bookings ENABLE ROW LEVEL SECURITY;
#
# CREATE POLICY "Allow public inserts on bookings"
#   ON bookings FOR INSERT TO anon WITH CHECK (true);
#
# CREATE POLICY "Allow authenticated reads on bookings"
#   ON bookings FOR SELECT TO authenticated USING (true);
#
# ============================================================
# (The full SQL is also saved in supabase/bookings_schema.sql)
# ============================================================

# ── Supabase: Slabs/Products table ───────────────────────────
